	Сотрудник.Вставить("Имя", "Илья");
	Сотрудник.Вставить("ДатаРождения", ТекущаяДата());
	Сотрудник.Вставить("Стаж", 15);
	Сотрудник.Вставить("Штатный", Ложь);
	
	Возврат Сотрудник;
КонецФункции


